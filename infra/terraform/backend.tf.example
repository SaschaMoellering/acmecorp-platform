# Copy this file to backend.tf and fill in your values before running terraform init.
# Do NOT commit backend.tf with real bucket/table names if they are environment-specific.

terraform {
  backend "s3" {
    bucket         = "<your-tfstate-bucket>"
    key            = "acmecorp-platform/prod/terraform.tfstate"
    region         = "eu-west-1"
    encrypt        = true
    dynamodb_table = "<your-tfstate-lock-table>"
  }
}
